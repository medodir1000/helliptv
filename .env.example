# ─────────────────────────────────────────────────────────────
#  HellIPTV — environment variables
#  Copy this file to ".env.local" (gitignored) and fill in real values.
#  These are read ONLY on the server side — never exposed to the browser.
# ─────────────────────────────────────────────────────────────

# Sports fixtures for /api/fixtures (the "next match" data).
# Optional — without a key it falls back to free public sources.

# Football-Data.org token (https://www.football-data.org/) — richer fixtures.
FOOTBALL_DATA_KEY=

# TheSportsDB key — the free public tier is simply "3".
THESPORTSDB_KEY=3

# Local dev only: set to 1 if a TLS-intercepting antivirus (e.g. Avast)
# breaks Node's outbound HTTPS during `npm run dev`. NEVER set in production.
DEV_INSECURE_TLS=
