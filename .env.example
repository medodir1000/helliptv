# ─────────────────────────────────────────────────────────────
#  HellIPTV — environment variables. Copy to ".env.local" (gitignored).
# ─────────────────────────────────────────────────────────────

# ── Supabase (blog + admin) — exposed to the browser (VITE_*) ──
# Safe to expose: the publishable/anon key is protected by Row Level Security.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Blog translations (/api/translate, server-side only) — set ONE provider ──
# OpenRouter (recommended — OpenAI-compatible): https://openrouter.ai/keys
# NOTE: ":free" models are rate-limited/flaky for bulk. For the 12-language
# "Translate all", a cheap PAID model is far more reliable (~$0.001/article):
#   OPENROUTER_MODEL=openai/gpt-4o-mini   (or google/gemini-flash-1.5)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# …or Google Gemini directly: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── AI article + image generation (/api/generate-article, /api/generate-image) ──
# Articles + image prompts reuse OPENROUTER_API_KEY above. Images use OpenAI:
# https://platform.openai.com/api-keys  (each article = 3 images, ~$0.04–0.12 each)
OPENAI_API_KEY=
# gpt-image-1 (best, needs a verified OpenAI org) → auto-falls back to dall-e-3.
OPENAI_IMAGE_MODEL=gpt-image-1
# Free, topic-relevant stock photos when OpenAI isn't available: https://www.pexels.com/api/
# Image fallback chain: OpenAI → Pexels → Picsum (keyless, always works). No key = Picsum.
PEXELS_API_KEY=

# ── Sports fixtures for /api/fixtures — server-side only ──
# Football-Data.org token (https://www.football-data.org/) — richer fixtures.
FOOTBALL_DATA_KEY=
# TheSportsDB key — the free public tier is simply "3".
THESPORTSDB_KEY=3

# Local dev only: set to 1 if a TLS-intercepting antivirus (e.g. Avast)
# breaks Node's outbound HTTPS during `npm run dev`. NEVER set in production.
DEV_INSECURE_TLS=
