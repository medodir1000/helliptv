# ─────────────────────────────────────────────────────────────
#  HellIPTV — environment variables. Copy to ".env.local" (gitignored).
# ─────────────────────────────────────────────────────────────

# ── Supabase (blog + admin) — exposed to the browser (VITE_*) ──
# Safe to expose: the publishable/anon key is protected by Row Level Security.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Sports fixtures for /api/fixtures — server-side only ──
# Football-Data.org token (https://www.football-data.org/) — richer fixtures.
FOOTBALL_DATA_KEY=
# TheSportsDB key — the free public tier is simply "3".
THESPORTSDB_KEY=3

# Local dev only: set to 1 if a TLS-intercepting antivirus (e.g. Avast)
# breaks Node's outbound HTTPS during `npm run dev`. NEVER set in production.
DEV_INSECURE_TLS=
